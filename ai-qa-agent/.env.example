
OPENAI_API_KEY=

# Base URL for the OpenAI-compatible API (default: https://api.openai.com/v1)
OPENAI_BASE_URL=https://api.openai.com/v1

# Model name to use for all LLM calls (default: gpt-4o)
LLM_MODEL=gpt-4o

# Cost in USD per token — used to compute CostPerExecution metric (default: 0.000001)
COST_PER_TOKEN=0.000001

# ── Database ─────────────────────────────────────────────────────────────────

# PostgreSQL connection string (REQUIRED)
# Format: postgresql://<user>:<password>@<host>:<port>/<database>
DATABASE_URL=postgresql://postgres:password@localhost:5432/qa_agent

# ── MCP Servers ──────────────────────────────────────────────────────────────

# Playwright MCP Server — stdio transport (spawned by the app)
PLAYWRIGHT_MCP_COMMAND=npx
PLAYWRIGHT_MCP_ARGS=@playwright/mcp

# File System MCP Server — stdio transport (spawned by the app)
FILESYSTEM_MCP_COMMAND=npx
# Comma-separated: <package>,<workspace-path>
FILESYSTEM_MCP_ARGS=@modelcontextprotocol/server-filesystem,/workspace

# PostgreSQL MCP Server — SSE transport (URL, optional — leave blank to disable)
POSTGRES_MCP_URL=http://localhost:5173

# GitHub MCP Server — SSE transport (URL, optional — leave blank to disable)
GITHUB_MCP_URL=http://localhost:5174

# ── Application ───────────────────────────────────────────────────────────────

# HTTP port the Express server listens on (default: 3000, range: 1–65535)
PORT=3000

# Timeout for individual MCP tool calls in ms (default: 30000, range: 1–300000)
MCP_TOOL_TIMEOUT_MS=30000

# Timeout for MCP server connection attempts in ms (default: 10000, range: 1–300000)
MCP_CONNECT_TIMEOUT_MS=10000

# Hallucination detection similarity threshold (default: 0.7, range: 0.0–1.0)
# Agent outputs below this similarity score are flagged as potential hallucinations.
HALLUCINATION_THRESHOLD=0.7

# Number of days to retain log entries (optional, range: 1–36500)
# Leave blank to retain all logs indefinitely.
LOG_RETENTION_DAYS=

# Directory where HTML session reports are written (default: ./reports)
REPORT_DIR=./reports
