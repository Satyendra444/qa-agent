{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    /* Relax some strict checks for test files */
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "strictPropertyInitialization": false,
    /* Include test directories */
    "rootDir": ".",
    "outDir": "dist-test",
    "baseUrl": "."
  },
  "include": [
    "src/**/*.ts",
    "tests/**/*.ts",
    "vitest.config.ts"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "dist-test"
  ]
}
